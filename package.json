{
  "name": "angular-micro-frontend",
  "private": true,
  "workspaces": [
    "angular-libs",
    "angular-menu",
    "angular-toolbar",
    "angular-overview",
    "angular-shell"
  ],
  "scripts": {
    "postinstall": "node scripts/install-native-bindings.js",
    "install:all": "npm install --legacy-peer-deps && npm run --workspaces install --if-present",
    "build:libs": "cd angular-libs && npx ng build broker --configuration production",
    "start": "concurrently -n menu,toolbar,overview,shell -c cyan,blue,magenta,green \"npm run start --workspace=angular-menu\" \"npm run start --workspace=angular-toolbar\" \"npm run start --workspace=angular-overview\" \"npm run start --workspace=angular-shell\"",
    "start:shell": "npm run start --workspace=angular-shell",
    "start:menu": "npm run start --workspace=angular-menu",
    "start:toolbar": "npm run start --workspace=angular-toolbar",
    "start:overview": "npm run start --workspace=angular-overview",
    "dev": "npm run build:libs && npm run start",
    "clean:nf": "rm -rf angular-shell/node_modules/.cache/native-federation angular-menu/node_modules/.cache/native-federation angular-toolbar/node_modules/.cache/native-federation angular-overview/node_modules/.cache/native-federation angular-shell/dist angular-menu/dist angular-toolbar/dist angular-overview/dist",
    "dev:clean": "npm run build:libs && npm run clean:nf && npm run start",
    "test:e2e": "npx playwright test --config=e2e/playwright.config.ts",
    "test:e2e:ui": "npx playwright test --config=e2e/playwright.config.ts --ui",
    "test:e2e:report": "npx playwright show-report"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@playwright/test": "^1.61.1",
    "concurrently": "^9.1.2",
    "http-proxy-middleware": "^3.0.7"
  },
  "dependencies": {
    "@primeng/themes": "^21.0.4"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "@angular-devkit/build-angular": {
      "http-proxy-middleware": "3.0.7",
      "@babel/core": "7.29.7"
    },
    "@angular/build": {
      "@babel/core": "7.29.7"
    }
  }
}
